  {
    "id": [ "TALK_DESCRIBE_SUPPLYDROP_PERSUADE_SUCCESS" ],
    "type": "talk_topic",
    "dynamic_line": "Wow, could it really do that?  Ok, please take it, and make sure to mention me when you save the world!",
